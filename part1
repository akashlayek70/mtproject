resource "aws_security_group" "pipeline_sg" {
  name        = "addressbook-pipeline-sg"
  description = "Allow inbound SSH and HTTP traffic"

  ingress {
    description = "SSH Access"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    description = "Web Application/Jenkins Access"
    from_port   = 8080
    to_port     = 8080
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }

  tags = {
    Name = "addressbook-sg"
  }
}

resource "aws_instance" "jenkins_server" {
  # This pulls the verified parameter string value dynamically
  ami                    = data.aws_ssm_parameter.ubuntu_lts.value 
  instance_type          = var.instance_type
  key_name               = var.key_name
  vpc_security_group_ids = [aws_security_group.pipeline_sg.id]

  tags = {
    Name = "Jenkins-CI-Server"
  }
}

resource "aws_instance" "tomcat_server" {
